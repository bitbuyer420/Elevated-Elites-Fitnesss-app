# Elevated Elites — Environment Variables
# Copy this file to .env.local and fill in your credentials.

# ── Supabase ────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Nutritionix API ─────────────────────────────────────────────
# Sign up at: https://developer.nutritionix.com
# Used by: /api/nutrition/search (food search with macros)
NUTRITIONIX_APP_ID=your-nutritionix-app-id
NUTRITIONIX_API_KEY=your-nutritionix-api-key

# ── Anthropic API ───────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
# Used by: /api/workout/suggest (AI workout recommendations)
ANTHROPIC_API_KEY=your-anthropic-api-key
